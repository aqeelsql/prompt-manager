DATABASE_URL=postgresql://postgres:password@localhost:5432/prompt_manager

PROMPT_SERVICE_PORT=8000
REVIEW_SERVICE_PORT=8001
LLM_SERVICE_PORT=8002
FILE_SERVICE_PORT=8003

PROMPT_SERVICE_URL=http://localhost:8000
REVIEW_SERVICE_URL=http://localhost:8001
LLM_SERVICE_URL=http://localhost:8002
FILE_SERVICE_URL=http://localhost:8003

OPENROUTER_API_KEY=replace_with_your_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-oss-20b
FALLBACK_MODEL=openai/gpt-4o-mini

LLM_CONNECT_TIMEOUT=5
LLM_READ_TIMEOUT=120
OPENROUTER_CONNECT_TIMEOUT=5
OPENROUTER_READ_TIMEOUT=50
PROMPT_CONNECT_TIMEOUT=5
PROMPT_READ_TIMEOUT=30
FILE_STORAGE_DIR=file_service/uploads
MAX_FILE_SIZE_MB=15
MAX_DOCUMENT_CONTEXT_CHARS=100000
FILE_CONNECT_TIMEOUT=5
FILE_READ_TIMEOUT=30
